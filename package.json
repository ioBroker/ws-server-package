{
  "name": "@iobroker/ws-server-library",
  "version": "5.0.0",
  "description": "This package allows to communicate different web applications with ioBroker.",
  "author": {
    "name": "bluefox",
    "email": "dogafox@gmail.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/ioBroker/ws-server-package",
  "keywords": [
    "ioBroker",
    "web"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ioBroker/ws-server-package"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@iobroker/socket-classes": "^2.3.6",
    "@iobroker/webserver": "^1.4.0",
    "@iobroker/ws-server": "^4.4.1",
    "body-parser": "^2.3.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "express-session": "^1.19.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/types": "^7.2.2",
    "@iobroker/ws": "^3.1.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.19.21",
    "@types/passport": "^1.0.17",
    "typescript": "~6.0.3"
  },
  "bugs": {
    "url": "https://github.com/ioBroker/ws-server-package/issues"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./socket.io.js": "./build/lib/socket.io.js"
  },
  "files": [
    "build/",
    "LICENSE"
  ],
  "scripts": {
    "test:integration": "mocha --exit",
    "test:package": "mocha test/testPackage.js --exit",
    "test": "npm run test:integration",
    "build": "tsc -p tsconfig.build.json && node tasks.mts",
    "lint": "eslint -c eslint.config.mjs",
    "release": "release-script",
    "release-patch": "release-script patch --yes",
    "release-minor": "release-script minor --yes",
    "release-major": "release-script major --yes",
    "update-packages": "npx -y npm-check-updates --upgrade",
    "npm": "npm i"
  },
  "license": "MIT",
  "readmeFilename": "README.md"
}
